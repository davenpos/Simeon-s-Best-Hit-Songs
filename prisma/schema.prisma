generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id Int @id @default(autoincrement())
  rank Int @unique
  title String
  artist String
  year Int
  year_end_pos Int
  hot_100_pos Int
  album String?
  isEP Boolean @default(false)
  cover String
  label String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}